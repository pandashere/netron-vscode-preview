{
  "name": "netron-vscode-preview",
  "displayName": "Netron VSCode Workbench",
  "description": "Preview ONNX models in VS Code with host-managed crop, export, inference, and compare workflows.",
  "version": "0.1.0",
  "publisher": "local",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pandashere/netron-vscode-preview.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization",
    "Machine Learning"
  ],
  "main": "./extension.js",
  "scripts": {
    "package:vsix": "npx @vscode/vsce package -o dist/netron-vscode-workbench-0.1.0.vsix",
    "install:vsix": "code --install-extension dist/netron-vscode-workbench-0.1.0.vsix --force",
    "verify:vsix": "code --list-extensions --show-versions",
    "generate:testmodels": "python3 scripts/generate_onnx_test_models.py --output-dir testdata/generated",
    "generate:vit-unet-3200": "python3 scripts/generate_vit_unet_3200_model.py",
    "benchmark:vit-unet-layout": "python3 scripts/benchmark_vit_unet_layout.py",
    "smoke:compare-internal": "node scripts/smoke_compare_internal_io.js"
  },
  "activationEvents": [
    "onCommand:netronPreview.openPreview",
    "onView:netronCompare.compareView",
    "onCommand:netronPreview.openCompareCenter",
    "onCommand:netronPreview.clearCompareCenter"
  ],
  "contributes": {
    "commands": [
      {
        "command": "netronPreview.openPreview",
        "title": "Netron: Preview Model"
      },
      {
        "command": "netronPreview.openCompareCenter",
        "title": "Netron: Focus Compare"
      },
      {
        "command": "netronPreview.clearCompareCenter",
        "title": "Netron: Clear Compare"
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "netronComparePanel",
          "title": "Netron Compare",
          "icon": "media/netron-compare.svg"
        }
      ]
    },
    "views": {
      "netronComparePanel": [
        {
          "type": "webview",
          "id": "netronCompare.compareView",
          "name": "Compare"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "netronPreview.openPreview",
          "when": "resourceScheme == file",
          "group": "navigation@100"
        }
      ]
    }
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "onnx-proto": "^8.0.1",
    "onnxruntime-node": "^1.24.3"
  }
}
